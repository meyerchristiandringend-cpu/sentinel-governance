{
    "technique":  "T1110",
    "name":  "password-spray",
    "version":  2,
    "pack":  "identity",
    "owner":  {
                  "slack":  "#soc-detections",
                  "oncall":  "sec-detect-oncall",
                  "team":  "identity-detection"
              },
    "bindings":  [
                     {
                         "bindingName":  "entra-id",
                         "pack":  "identity",
                         "sourceFunction":  "fn_identity_failed_logins_v1",
                         "where":  "Result != \u0027Success\u0027",
                         "reduce":  "summarize failures = count(), cnt = count() by UserPrincipalName, bin(TimeGenerated, 5m)",
                         "entities":  [
                                          {
                                              "type":  "Account",
                                              "field":  "UserPrincipalName"
                                          }
                                      ],
                         "metadata":  {
                                          "displayName":  "T1110 Password Spray - Entra ID",
                                          "domain":  "identity",
                                          "severity":  "Medium",
                                          "lifecycle":  "production"
                                      }
                     },
                     {
                         "bindingName":  "vpn",
                         "pack":  "network",
                         "sourceFunction":  "fn_network_vpn_auth_failures_v1",
                         "where":  "Result == \u0027Failure\u0027",
                         "reduce":  "summarize cnt = count() by SrcIP, bin(TimeGenerated, 5m)",
                         "entities":  [
                                          {
                                              "type":  "Ip",
                                              "field":  "SrcIP"
                                          }
                                      ],
                         "metadata":  {
                                          "displayName":  "T1110 Password Spray - VPN",
                                          "domain":  "network",
                                          "severity":  "Medium",
                                          "lifecycle":  "experimental"
                                      }
                     }
                 ]
}
