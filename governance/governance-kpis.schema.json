{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/sentinel/governance-kpis.schema.json",
  "title": "Governance KPI Snapshot",
  "type": "object",
  "required": [
    "generated_at_utc",
    "quarter",
    "overall_status",
    "kpis"
  ],
  "properties": {
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "quarter": {
      "type": "string",
      "pattern": "^\\d{4}-Q[1-4]$"
    },
    "overall_status": {
      "type": "string",
      "enum": ["green", "yellow", "red"]
    },
    "kpis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "category",
          "target",
          "value",
          "status",
          "severity",
          "source",
          "timestamp_utc"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["green", "yellow", "red"]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "timestamp_utc": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
