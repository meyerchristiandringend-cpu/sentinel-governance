{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/detection-rule.schema.json",
  "title": "Detection Rule",
  "type": "object",
  "required": ["id", "name", "query", "metadata"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "query": { "type": "string" },
    "metadata": {
      "type": "object",
      "required": ["owner"],
      "properties": {
        "owner": {
          "type": "object",
          "required": ["team", "slack", "oncall"],
          "properties": {
            "team": { "type": "string" },
            "slack": { "type": "string", "pattern": "^#" },
            "oncall": { "type": "string" }
          },
          "additionalProperties": false
        },
        "mitre_techniques": {
          "type": "array",
          "items": { "type": "string", "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
